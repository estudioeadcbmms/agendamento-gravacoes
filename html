<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Agendamento de Gravações CFS - 2026</title>

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet">

<style>
body { font-family: Arial; margin: 0; background:#0f172a; color:white; }
#calendar { max-width: 900px; margin: 40px auto; background:white; color:black; padding:10px; border-radius:10px;}
</style>

</head>
<body>

<h2 style="text-align:center">Agendamento de Gravações</h2>
<div id="calendar"></div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>

<!-- FIREBASE -->
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js"></script>

<script>

// 🔥 COLE AQUI SUAS CREDENCIAIS FIREBASE
const firebaseConfig = {
  apiKey: "SUA_KEY",
  authDomain: "SEU_DOMINIO",
  projectId: "SEU_ID"
};

firebase.initializeApp(firebaseConfig);
const db = firebase.firestore();

function definirPeriodo(hora){
    if(hora >= 7 && hora < 12){
        return {inicio:"07:00", fim:"12:00", periodo:"manha"};
    }
    if(hora >= 13 && hora < 17){
        return {inicio:"13:30", fim:"17:00", periodo:"tarde"};
    }
    return null;
}

document.addEventListener('DOMContentLoaded', async function() {

    const calendar = new FullCalendar.Calendar(document.getElementById('calendar'), {
        initialView: 'dayGridMonth',
        locale: 'pt-br',

        dateClick: async function(info) {

            let hora = prompt("Digite a hora (ex: 9 ou 14)");

            if(!hora) return;

            hora = parseInt(hora);

            const periodoInfo = definirPeriodo(hora);

            if(!periodoInfo){
                alert("Horário inválido!");
                return;
            }

            const data = info.dateStr;

            // VERIFICAR SE JÁ EXISTE
            const consulta = await db.collection("agendamentos")
                .where("data","==",data)
                .where("periodo","==",periodoInfo.periodo)
                .get();

            if(!consulta.empty){
                alert("Esse período já está ocupado!");
                return;
            }

            if(confirm(`Seu horário será das ${periodoInfo.inicio} até ${periodoInfo.fim}. Confirmar?`)){

                await db.collection("agendamentos").add({
                    data: data,
                    periodo: periodoInfo.periodo,
                    inicio: periodoInfo.inicio,
                    fim: periodoInfo.fim
                });

                alert("Agendado com sucesso!");
                location.reload();
            }
        },

        events: async function(fetchInfo, successCallback) {

            const snapshot = await db.collection("agendamentos").get();

            const eventos = [];

            snapshot.forEach(doc => {
                const d = doc.data();

                eventos.push({
                    title: d.periodo.toUpperCase(),
                    start: d.data,
                    color: d.periodo === "manha" ? "orange" : "blue"
                });
            });

            successCallback(eventos);
        }

    });

    calendar.render();
});

</script>

</body>
</html>
